{"type":"message","id":"de4e6147","parentId":"2d81292e","timestamp":"2026-04-25T03:37:27.901Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_DzaDJiLYT3dKGwgvbL5l4SsW|fc_00307533e672fab70169ec36f6e6f081948fe72e2919745c25","name":"read","arguments":{"limit":220,"offset":1,"path":"~/.openclaw/skills/gpt-image-generator/scripts/generate_image.py"},"partialJson":"{\"limit\":220,\"offset\":1,\"path\":\"~/.openclaw/skills/gpt-image-generator/scripts/generate_image.py\"}"}],"api":"openai-responses","provider":"openai","model":"gpt-5.4","usage":{"input":46556,"output":40,"cacheRead":0,"cacheWrite":0,"totalTokens":46596,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1777088242226,"responseId":"resp_00307533e672fab70169ec36f38b1081949630b19c46b6b675"}}
{"type":"message","id":"8ff363a0","parentId":"de4e6147","timestamp":"2026-04-25T03:37:28.104Z","message":{"role":"toolResult","toolCallId":"call_DzaDJiLYT3dKGwgvbL5l4SsW|fc_00307533e672fab70169ec36f6e6f081948fe72e2919745c25","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nimport argparse\nimport base64\nimport json\nimport os\nimport sys\nfrom pathlib import Path\nfrom urllib import request, error\n\nDEFAULT_API_URL = os.environ.get('PY_IMAGE_GEN_API_URL', 'http://127.0.0.1:8317/v1/responses')\nDEFAULT_API_KEY = [REDACTED]'PY_IMAGE_GEN_API_KEY', 'sk-xxxxx')\nDEFAULT_MODEL = os.environ.get('PY_IMAGE_GEN_MODEL', 'gpt-image-1536x1024')\nDEFAULT_INSTRUCTIONS = os.environ.get('PY_IMAGE_GEN_INSTRUCTIONS', 'You are a helpful assistant.')\n\n\ndef save_bytes(path: Path, b64: str):\n    path.write_bytes(base64.b64decode(b64))\n    print(f'SAVED {path}')\n\n\ndef parse_sse_and_save(resp, out_base: str):\n    event_type = None\n    data_lines = []\n    saved = None\n\n    def flush():\n        nonlocal event_type, data_lines, saved\n        if not event_type or not data_lines:\n            return\n        raw = '\\n'.join(data_lines).strip()\n        if not raw or raw == '[DONE]':\n            event_type = None\n            data_lines = []\n            return\n        try:\n            obj = json.loads(raw)\n        except Exception:\n            event_type = None\n            data_lines = []\n            return\n\n        def save_image_call(image_call):\n            nonlocal saved\n            if not image_call:\n                return\n            if image_call.get('type') != 'image_generation_call':\n                return\n            result = image_call.get('result')\n            if not result:\n                return\n            ext = image_call.get('output_format') or 'png'\n            out_path = Path.cwd() / f'{out_base}.{ext}'\n            save_bytes(out_path, result)\n            saved = str(out_path)\n\n        if event_type == 'response.output_item.done':\n            save_image_call(obj.get('item'))\n        elif event_type == 'response.completed':\n            response = obj.get('response', {})\n            for item in response.get('output', []) or []:\n                if item.get('type') == 'image_generation_call' and item.get('result'):\n                    save_image_call(item)\n                    break\n        event_type = None\n        data_lines = []\n\n    for raw_line in resp:\n        line = raw_line.decode('utf-8', errors='ignore').rstrip('\\r\\n')\n        if line.startswith('event:'):\n            if event_type or data_lines:\n                flush()\n            event_type = line[6:].strip()\n        elif line.startswith('data:'):\n            data_lines.append(line[5:].lstrip())\n        elif not line.strip():\n            flush()\n    flush()\n    return saved\n\n\ndef main():\n    parser = argparse.ArgumentParser(description='Generate image via responses API and save beside script caller cwd.')\n    parser.add_argument('prompt', help='image prompt')\n    parser.add_argument('--api-url', default=DEFAULT_API_URL)\n    parser.add_argument('--api-key', default=DEFAULT_API_KEY)\n    parser.add_argument('--model', default=DEFAULT_MODEL)\n    parser.add_argument('--instructions', default=DEFAULT_INSTRUCTIONS)\n    parser.add_argument('--out-base', default='generated')\n    args = parser.parse_args()\n\n    body = {\n        'model': args.model,\n        'instructions': args.instructions,\n        'input': [{\n            'type': 'message',\n            'role': 'user',\n            'content': [{\n                'type': 'input_text',\n                'text': args.prompt,\n            }],\n        }],\n        'parallel_tool_calls': True,\n        'reasoning': {'effort': 'high', 'summary': 'auto'},\n        'stream': True,\n        'store': False,\n        'include': ['reasoning.encrypted_content'],\n    }\n\n    data = json.dumps(body, ensure_ascii=False).encode('utf-8')\n    req = request.Request(args.api_url, data=data, method='POST')\n    req.add_header('Content-Type', 'application/json')\n    req.add_header('Authorization', f'Bearer {args.api_key}')\n\n    try:\n        with request.urlopen(req, timeout=600) as resp:\n            saved = parse_sse_and_save(resp, args.out_base)\n    except error.HTTPError as e:\n        detail = e.read().decode('utf-8', errors='ignore')\n        print(f'HTTP_ERROR {e.code} {detail}', file=sys.stderr)\n        raise SystemExit(1)\n    except Exception as e:\n        print(f'ERROR {e}', file=sys.stderr)\n        raise SystemExit(1)\n\n    if not saved:\n        print('ERROR no_image_saved', file=sys.stderr)\n        raise SystemExit(2)\n    print(f'OK {saved}')\n\n\nif __name__ == '__main__':\n    main()\n"}],"isError":false,"timestamp":1777088247971}}
