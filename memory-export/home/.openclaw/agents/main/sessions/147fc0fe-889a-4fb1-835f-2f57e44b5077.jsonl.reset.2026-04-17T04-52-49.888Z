lePath\": \"/vol1/@apphome/trim.openclaw/data/home/.openclaw/skills/word-docx/SKILL.md\",\n          \"baseDir\": \"/vol1/@apphome/trim.openclaw/data/home/.openclaw/skills/word-docx\",\n          \"source\": \"openclaw-managed\",\n          \"sourceInfo\": {\n            \"path\": \"/vol1/@apphome/trim.openclaw/data/home/.openclaw/skills/word-docx/SKILL.md\",\n            \"source\": \"openclaw-managed\",\n            \"scope\": \"project\",\n            \"origin\": \"top-level\",\n            \"baseDir\": \"/vol1/@apphome/trim.openclaw/data/home/.openclaw/skills/word-docx\"\n          },\n          \"disableModelInvocation\": false\n        },\n        {\n          \"name\": \"yaohuo\",\n          \"description\": \"Use when Codex needs to log in to yaohuo.me over HTTP, save or import Yaohuo cookies, validate whether a Yaohuo session is still logged in, draft a forum topic, and publish a new thread to the fixed \\\"闲聊灌水\\\" board after user confirmation. Trigger this skill for requests about 妖火网发帖, 妖火登录, Cookie 持久化, Cookie 是否有效, HTTP 表单提交, or preparing title/body text for a Yaohuo topic without browser automation.\",\n          \"filePath\": \"/vol1/@apphome/trim.openclaw/data/home/.openclaw/skills/yaohuo/SKILL.md\",\n          \"baseDir\": \"/vol1/@apphome/trim.openclaw/data/home/.openclaw/skills/yaohuo\",\n          \"source\": \"openclaw-managed\",\n          \"sourceInfo\": {\n            \"path\": \"/vol1/@apphome/trim.openclaw/data/home/.openclaw/skills/yaohuo/SKILL.md\",\n            \"source\": \"openclaw-managed\",\n            \"scope\": \"project\",\n            \"origin\": \"top-level\",\n            \"baseDir\": \"/vol1/@apphome/trim.openclaw/data/home/.openclaw/skills/yaohuo\"\n          },\n          \"disableModelInvocation\": false\n        }\n      ],\n      \"version\": 0\n    },\n    \"totalTokensFresh\": false\n  },\n  \"agent:main:openclaw-weixin:group:o9cq801efmzr029dhzr2bs9tb10e@im.wechat\": {\n    \"chatType\": \"group\",\n    \"channel\": 