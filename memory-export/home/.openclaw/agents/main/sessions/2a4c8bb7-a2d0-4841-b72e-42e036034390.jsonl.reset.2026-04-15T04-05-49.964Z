{"type":"message","id":"2e6be75d","parentId":"3b1317e1","timestamp":"2026-04-14T10:41:18.466Z","message":{"role":"toolResult","toolCallId":"call_WfAIfO6168CAENuWGOv8ruTE|fc_0b21e23afab3bd860169de19940a8081938731f79098587cd4","toolName":"exec","content":[{"type":"text","text":"/vol1/@apphome/trim.openclaw/data/openclaw/node_modules/openclaw/docs/cli/mcp.md"}],"details":{"status":"completed","exitCode":0,"durationMs":47,"aggregated":"/vol1/@apphome/trim.openclaw/data/openclaw/node_modules/openclaw/docs/cli/mcp.md","cwd":"/vol1/@apphome/trim.openclaw/data/workspace"},"isError":false,"timestamp":1776163278462}}
