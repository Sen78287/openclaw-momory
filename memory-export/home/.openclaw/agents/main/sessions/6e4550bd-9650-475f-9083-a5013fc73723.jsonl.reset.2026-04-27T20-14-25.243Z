ity) agents=(unity-*) ;;\\n  unreal) agents=(unreal-*) ;;\\n  visionos) agents=(visionos-*) ;;\\n  xr) agents=(xr-*) ;;\\n  misc) agents=(accounts-payable-agent agentic-identity-trust agents-orchestrator automation-governance-architect blender-addon-engineer blockchain-security-auditor compliance-auditor corporate-training-designer data-consolidation-agent gaokao-college-advisor government-digital-presales-consultant healthcare-customer-service healthcare-marketing-compliance hospitality-guest-services identity-graph-operator language-translator level-designer loan-officer-assistant lsp-index-engineer macos-spatial-metal-engineer narrative-designer project-manager-senior prompt-engineer real-estate-buyer-seller recruitment-specialist report-distribution-agent retail-customer-returns study-abroad-advisor technical-artist technical-translator-agent terminal-integration-specialist zk-steward) ;;\\n  *) echo \\\"unknown batch: $BATCH_NAME\\\"; exit 1 ;;\\nesac\\ncd \\\"$REPO\\\"\\ncount=0\\nfor name in \\\"${agents[@]}\\\"; do\\n  [[ -d \\\"$name\\\" ]] || continue\\n  mkdir -p \\\"$DEST/$name\\\"\\n  cp \\\"$name/SOUL.md\\\" \\\"$DEST/$name/SOUL.md\\\"\\n  cp \\\"$name/AGENTS.md\\\" \\\"$DEST/$name/AGENTS.md\\\"\\n  cp \\\"$name/IDENTITY.md\\\" \\\"$DEST/$name/IDENTITY.md\\\"\\n  if openclaw agents list 2>/dev/null | grep -q \\\"$name\\\"; then\\n    echo \\\"skip registered: $name\\\"\\n  else\\n    timeout 30 openclaw agents add \\\"$name\\\" --workspace \\\"$DEST/$name\\\" --non-interactive 2>/dev/null || true\\n  fi\\n  count=$((count+1))\\n  echo \\\"done $count: $name\\\"\\ndone\\n\"}"}],"api":"openai-responses","provider":"openai","model":"gpt-5.4","usage":{"input":7837,"output":784,"cacheRead":91648,"cacheWrite":0,"totalTokens":100269,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1777292899147,"responseId":"resp_06da932db866b0fd0169ef5664f46481939e658744ef6803c8"}}
