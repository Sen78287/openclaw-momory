/dist/subsystem-BDbeCphF.js:944:46\",\"fileName\":\"subsystem-BDbeCphF.js\",\"fileNameWithLine\":\"subsystem-BDbeCphF.js:944\",\"fileColumn\":\"46\",\"fileLine\":\"944\",\"filePath\":\"node_modules/openclaw/dist/subsystem-BDbeCphF.js\",\"filePathWithLine\":\"node_modules/openclaw/dist/subsystem-BDbeCphF.js:944\",\"method\":\"console.info\"}},\"time\":\"2026-04-05T07:55:06.685+08:00\"}\n739:{\"0\":\"[info]: [ 'event-dispatch is ready' ]\",\"_meta\":{\"runtime\":\"node\",\"runtimeVersion\":\"22.18.0\",\"hostname\":\"unknown\",\"name\":\"openclaw\",\"date\":\"2026-04-04T23:59:59.349Z\",\"logLevelId\":3,\"logLevelName\":\"INFO\",\"path\":{\"fullFilePath\":\"file:///vol1/@apphome/trim.openclaw/data/openclaw/node_modules/openclaw/dist/subsystem-BDbeCphF.js:944:46\",\"fileName\":\"subsystem-BDbeCphF.js\",\"fileNameWithLine\":\"subsystem-BDbeCphF.js:944\",\"fileColumn\":\"46\",\"fileLine\":\"944\",\"filePath\":\"node_modules/openclaw/dist/subsystem-BDbeCphF.js\",\"filePathWithLine\":\"node_modules/openclaw/dist/subsystem-BDbeCphF.js:944\",\"method\":\"console.info\"}},\"time\":\"2026-04-05T07:59:59.350+08:00\"}\n741:{\"0\":\"[info]: [\\n  '[ws]',\\n  'receive events or callbacks through persistent connection only available in self-build & Feishu app, Configured in:\\\\n' +\\n    '        Developer Console(ćŒćèćć°) \\\\n' +\\n    '          ->\\\\n' +\\n    '        Events and Callbacks(äșä»¶äžćè°)\\\\n' +\\n    '          -> \\\\n' +\\n    '        Mode of event/callback subscription(èźąéæčćŒ)\\\\n' +\\n    '          -> \\\\n' +\\n    '        Receive events/callbacks through persistent connection(äœżçš éżèżæ„ æ„æ¶äșä»¶/ćè°)'\\n]\",\"_meta\":{\"runtime\":\"node\",\"runtimeVersion\":\"22.18.0\",\"hostname\":\"unknown\",\"name\":\"openclaw\",\"date\":\"2026-04-04T23:59:59.379Z\",\"logLevelId\":3,\"logLevelName\":\"INFO\",\"path\":{\"fullFilePath\":\"file:///vol1/@apphome/trim.openclaw/data/openclaw/node_modules/openclaw/dist/subsystem-BDbeCphF.js:9