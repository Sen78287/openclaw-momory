sole.log('  openclaw config set session.dmScope \"per-account-channel-peer\"');\n  }\n  \n  // éćŻ\n  log.warning('æ­ŁćšéćŻ Gateway...');\n  try {\n    execSync('openclaw gateway restart', { stdio: 'inherit' });\n    log.success('Gateway éćŻćźæ');\n  } catch (err) {\n    log.error(`éćŻć€±èŽ„: ${err.message}`);\n    log.info('èŻ·æćšæ§èĄ: openclaw gateway restart');\n  }\n  \n  // ćźææç€ș\n  console.log('\\n' + 'â'.repeat(50));\n  log.success('éçœźćźæïŒ');\n  console.log('\\néçœźæèŠ:');\n  console.log(`  èŽŠæ· ID: ${accountId}`);\n  console.log(`  è·Żç±æšĄćŒ: ${mode}`);\n  if (agentid) console.log(`  Agent: ${agentid}`);\n  if (chatid) console.log(`  çŸ€è: ${chatid}`);\n  console.log('\\nćŠéçœźæèŻŻïŒćŻä»ć€ä»œæąć€:');\n  console.log(`  cp ${backupPath} ${CONFIG_PATH}`);\n  console.log('â'.repeat(50) + '\\n');\n}\n\n// ć€çćœä»€èĄćæ°\nfunction parseArgs() {\n  const args = process.argv.slice(2);\n  const options = {};\n  \n  for (let i = 0; i < args.length; i++) {\n    const arg = args[i];\n    if (arg.startsWith('--')) {\n      const key = arg.slice(2).replace(/-/g, '');\n      const value = args[i + 1] && !args[i + 1].startsWith('--') ? args[i + 1] : 'true';\n      options[key] = value;\n      if (value !== 'true') i++;\n    }\n  }\n  \n  return options;\n}\n\n// äž»ć„ćŁ\nconst options = parseArgs();\n\nif (options.help || options.h) {\n  showRoutingOptions();\n  console.log(`\n${colors.bold}çšæł:${colors.reset}\n  node index.js [ééĄč]\n\n${colors.bold}ééĄč:${colors.reset}\n  --app-id <id>          éŁäčŠ App ID (ćżćĄ«)\n  --app-secret <secret>  éŁäčŠ App Secret (ćżćĄ«)\n  --account-id <id>      èŽŠæ·æ èŻ (ćŻé, é»èź€èȘćšçæ)\n  --bot-name <name>      æșćšäșșćç§° (ćŻé)\n  --dm-policy <policy>   DM ç­ç„: open/pairing/allowlist (é»èź€: open)\n  --agent-id <id>        èŠç»ćźç Agent ID (ćŻé)\n  --chat-id <id>         çŸ€è ID oc_xxx (çŸ€èç»ćźæ¶éèŠ)\n  --routing