\"31181\":83956,\"27577\":70968,\"32073\":118725,\"27\n\n\nProcess exited with code 0."}],"details":{"status":"completed","sessionId":"quiet-fjord","exitCode":0,"aggregated":"\n=== /timeTable/v5.30.0/getPricesDtail.do {'priceId': '1600'} ===\nstatus 200\n{\"msg\":\"操作成功\",\"code\":200,\"data\":{\"basepath\":\"http://www.xinghengclass.com\",\"videoDdurationMap\":{\"27528\":136633,\"32126\":28179,\"32127\":18212,\"31312\":14934,\"32125\":37453,\"28895\":44662,\"31315\":101181,\"30105\":155274,\"30609\":43790,\"27579\":75518,\"30093\":130097,\"31181\":83956,\"27577\":70968,\"32073\":118725,\"27\n\n=== /timeTable/v5.30.0/getPricesDtail.do {'id': '1600'} ===\nstatus 200\n{\"msg\":\"priceId不可为空!\",\"code\":300}\n\n=== /timeTable/v5.30.0/getPricesDtail.do {'videoId': '7CDB1897C30D1593B463AB73BD4C026B'} ===\nstatus 200\n{\"msg\":\"priceId不可为空!\",\"code\":300}\n\n=== /timeTable/v5.30.0/getPricesDtail.do {'vid': '7CDB1897C30D1593B463AB73BD4C026B'} ===\nstatus 200\n{\"msg\":\"priceId不可为空!\",\"code\":300}\n\n=== /timeTable/v5.30.0/getPricesDtail.do {'priceId': '1600', 'vid': '7CDB1897C30D1593B463AB73BD4C026B'} ===\nstatus 200\n{\"msg\":\"操作成功\",\"code\":200,\"data\":{\"basepath\":\"http://www.xinghengclass.com\",\"videoDdurationMap\":{\"27528\":136633,\"32126\":28179,\"32127\":18212,\"31312\":14934,\"32125\":37453,\"28895\":44662,\"31315\":101181,\"30105\":155274,\"30609\":43790,\"27579\":75518,\"30093\":130097,\"31181\":83956,\"27577\":70968,\"32073\":118725,\"27\n\n=== /timeTable/v5.30.0/getPricesDtail.do {'priceId': '1600', 'videoId': '7CDB1897C30D1593B463AB73BD4C026B'} ===\nstatus 200\n{\"msg\":\"操作成功\",\"code\":200,\"data\":{\"basepath\":\"http://www.xinghengclass.com\",\"videoDdurationMap\":{\"27528\":136633,\"32126\":28179,\"32127\":18212,\"31312\":14934,\"32125\":37453,\"28895\":44662,\"31315\":101181,\"30105\":155274,\"30609\":43790,\"27579\":75518,\"30093\":130097,\"31181\":83956,\"27577\":70968,\"32073\":118725,\"27\n","name":"python3 <<'PY'"},"isError":false,"timest