xt[:2000])\\nexcept Exception as e:\\n    print('EXC',repr(e))\\nPY\",\"workdir\":\"/vol1/@apphome/trim.openclaw/data/workspace\",\"timeout\":120,\"yieldMs\":1000}"}],"api":"openai-responses","provider":"openai","model":"gpt-5.4","usage":{"input":135073,"output":297,"cacheRead":0,"cacheWrite":0,"totalTokens":135370,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1777106401659,"responseId":"resp_06f6707160cd42800169ec7de7b5ec8190b71564ddae0a0c07"}}
