d":"","threadName":"","timeoutMs":120000,"topic":"","type":0,"unionId":"","until":"","userId":""},"partialJson":"{\"accountId\":\"3b92905a192c-im-bot\",\"action\":\"send\",\"activityName\":\"\",\"activityState\":\"\",\"activityType\":\"custom\",\"activityUrl\":\"\",\"after\":\"\",\"appliedTags\":[],\"around\":\"\",\"asDocument\":false,\"asVoice\":false,\"authorId\":\"\",\"authorIds\":[],\"autoArchiveMin\":60,\"before\":\"\",\"bestEffort\":false,\"buffer\":\"\",\"caption\":\"\",\"categoryId\":\"\",\"channel\":\"openclaw-weixin\",\"channelId\":\"\",\"channelIds\":[],\"chatId\":\"o9cq801eFMZr029DhzR2Bs9tB10E@im.wechat\",\"clearParent\":false,\"contentType\":\"\",\"deleteDays\":0,\"desc\":\"\",\"dryRun\":false,\"durationMin\":0,\"effect\":\"\",\"effectId\":\"\",\"emoji\":\"\",\"emojiName\":\"\",\"endTime\":\"\",\"eventName\":\"\",\"eventType\":\"\",\"filePath\":\"\",\"filename\":\"\",\"forceDocument\":false,\"fromMe\":false,\"gatewayToken\":\"\",\"gatewayUrl\":\"\",\"gifPlayback\":false,\"groupId\":\"\",\"guildId\":\"\",\"image\":\"\",\"includeArchived\":false,\"includeMembers\":false,\"kind\":\"\",\"limit\":50,\"location\":\"\",\"media\":\"/vol1/@apphome/trim.openclaw/data/workspace/generated-images/06-conclusion.png\",\"memberId\":\"\",\"memberIdType\":\"open_id\",\"members\":false,\"message\":\"第 6 张\",\"messageId\":\"\",\"message_id\":\"\",\"mimeType\":\"\",\"name\":\"\",\"nsfw\":false,\"openId\":\"\",\"pageSize\":50,\"pageToken\":\"\",\"parentId\":\"\",\"participant\":\"\",\"path\":\"\",\"pollDurationHours\":0,\"pollId\":\"\",\"pollMulti\":false,\"pollOption\":[],\"pollOptionId\":\"\",\"pollOptionIds\":[],\"pollOptionIndex\":0,\"pollOptionIndexes\":[],\"pollQuestion\":\"\",\"position\":0,\"query\":\"\",\"quoteText\":\"\",\"rateLimitPerUser\":0,\"reason\":\"\",\"remove\":false,\"replyTo\":\"\",\"roleId\":\"\",\"roleIds\":[],\"scope\":\"\",\"silent\":false,\"startTime\":\"\",\"status\":\"online\",\"stickerDesc\":\"\",\"stickerId\":[],\"stickerName\":\"\",\"stickerTag