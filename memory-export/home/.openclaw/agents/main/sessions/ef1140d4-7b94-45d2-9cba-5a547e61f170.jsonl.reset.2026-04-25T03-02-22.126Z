{"type":"message","id":"7367e4ce","parentId":"d7a28d73","timestamp":"2026-04-24T11:52:36.403Z","message":{"role":"toolResult","toolCallId":"call_170kJQTM0TP1voKwsIcvbP5n|fc_043e95980f4055d30169eb59794e108197b817be526e6bfe6f","toolName":"message","content":[{"type":"text","text":"{\n  \"channel\": \"openclaw-weixin\",\n  \"to\": \"o9cq801eFMZr029DhzR2Bs9tB10E@im.wechat\",\n  \"via\": \"direct\",\n  \"mediaUrl\": \"/vol1/@apphome/trim.openclaw/data/workspace/generated-images/binli-crane-background.png\",\n  \"mediaUrls\": [\n    \"/vol1/@apphome/trim.openclaw/data/workspace/generated-images/binli-crane-background.png\"\n  ],\n  \"result\": {\n    \"channel\": \"openclaw-weixin\",\n    \"messageId\": \"openclaw-weixin:1777031555768-556f8bea\"\n  }\n}"}],"details":{"channel":"openclaw-weixin","to":"o9cq801eFMZr029DhzR2Bs9tB10E@im.wechat","via":"direct","mediaUrl":"/vol1/@apphome/trim.openclaw/data/workspace/generated-images/binli-crane-background.png","mediaUrls":["/vol1/@apphome/trim.openclaw/data/workspace/generated-images/binli-crane-background.png"],"result":{"channel":"openclaw-weixin","messageId":"openclaw-weixin:1777031555768-556f8bea"}},"isError":false,"timestamp":1777031556350}}
