ke.err &\\nPID=$!\\nsleep 6\\nkill $PID >/dev/null 2>&1 || true\\nprintf '%s\\\\n' '--- STDERR ---'\\nsed -n '1,200p' /tmp/github-mcp-handshake.err\\nprintf '%s\\\\n' '--- STDOUT ---'\\nsed -n '1,260p' /tmp/github-mcp-handshake.out\",\"timeout\":30,\"yieldMs\":1000}"}],"api":"openai-responses","provider":"openai","model":"gpt-5.4","usage":{"input":6112,"output":314,"cacheRead":81408,"cacheWrite":0,"totalTokens":87834,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1777567525980,"responseId":"resp_00cf43d14e6c06b40169f38727888c819798ec606c2e124a4b"}}
