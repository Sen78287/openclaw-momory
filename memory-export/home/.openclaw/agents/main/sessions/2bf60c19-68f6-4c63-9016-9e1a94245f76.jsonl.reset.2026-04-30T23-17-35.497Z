/tools/debug-screenshot.ts\n/tmp/openpencil/packages/pen-mcp/src/tools/debug-validation-report.ts\n/tmp/openpencil/packages/pen-mcp/src/tools/design-content.ts\n/tmp/openpencil/packages/pen-mcp/src/tools/design-md.ts\n/tmp/openpencil/packages/pen-mcp/src/tools/design-prompt.ts\n/tmp/openpencil/packages/pen-mcp/src/tools/design-refine.ts\n/tmp/openpencil/packages/pen-mcp/src/tools/design-skeleton.ts\n/tmp/openpencil/packages/pen-mcp/src/tools/find-empty-space.ts\n/tmp/openpencil/packages/pen-mcp/src/tools/get-selection.ts\n/tmp/openpencil/packages/pen-mcp/src/tools/import-svg.ts\n/tmp/openpencil/packages/pen-mcp/src/tools/layered-design-defs.ts\n/tmp/openpencil/packages/pen-mcp/src/tools/node-crud.ts\n/tmp/openpencil/packages/pen-mcp/src/tools/open-document.ts\n/tmp/openpencil/packages/pen-mcp/src/tools/pages.ts\n/tmp/openpencil/packages/pen-mcp/src/tools/read-nodes.ts\n/tmp/openpencil/packages/pen-mcp/src/tools/snapshot-layout.ts\n/tmp/openpencil/packages/pen-mcp/src/tools/theme-presets.ts\n/tmp/openpencil/packages/pen-mcp/src/tools/variables.ts\n/tmp/openpencil/packages/pen-mcp/src/utils/design-md-parser.ts\n/tmp/openpencil/packages/pen-mcp/src/utils/design-md-style-policy.ts\n/tmp/openpencil/packages/pen-mcp/src/utils/id.ts\n/tmp/openpencil/packages/pen-mcp/src/utils/log-utils.ts\n/tmp/openpencil/packages/pen-mcp/src/utils/node-operations.ts\n/tmp/openpencil/packages/pen-mcp/src/utils/sanitize.ts\n/tmp/openpencil/packages/pen-mcp/src/utils/svg-node-parser.ts\n/tmp/openpencil/packages/pen-mcp/src/utils/validate-contract.ts\n\n--- CLI COMMAND FILES ---\n/tmp/openpencil/apps/cli/src/commands/app.ts\n/tmp/openpencil/apps/cli/src/commands/codegen.ts\n/tmp/openpencil/apps/cli/src/commands/design.ts\n/tmp/openpencil/apps/cli/src/commands/document.ts\n/tmp/openpencil/apps/cli/src/commands/import.ts\n/tmp/openpencil/apps/cli/src/commands/install.ts\n/tmp/openpencil/apps/cli/src/commands/layout.ts\n/tmp/openpencil/apps/cli/src/commands/nodes.ts\n/tmp/openpencil/apps/cli/src