         \\\"timezone\\\": \\\"Asia/Shanghai\\\"\\n        },\\n        \\\"prompt\\\": \\\"Read HEARTBEAT.md if it exists (workspace context). Follow it strictly. Do not infer or repeat old tasks from prior chats. If nothing needs attention, reply HEARTBEAT_OK.\\\"\\n      }\\n    }\\n  }\\n}\\n```\\n\\n---\\n\\n## 按你当前文件结构，合并后的脱敏预览长这样\\n\\n```json5\\n{\\n  \\\"meta\\\": {\\n    \\\"lastTouchedVersion\\\": \\\"2026.3.13\\\",\\n    \\\"lastTouchedAt\\\": \\\"2026-03-28T07:43:37.279Z\\\"\\n  },\\n  \\\"models\\\": {\\n    \\\"providers\\\": {\\n      \\\"openai\\\": {\\n        \\\"baseUrl\\\": \\\"http://***:8080/v1\\\",\\n        \\\"apiKey\\\": \\\"***\\\",\\n        \\\"models\\\": [\\n          {\\n            \\\"id\\\": \\\"gpt-5.4\\\",\\n            \\\"name\\\": \\\"GPT-5.4\\\"\\n          }\\n        ]\\n      }\\n    }\\n  },\\n  \\\"agents\\\": {\\n    \\\"defaults\\\": {\\n      \\\"models\\\": {\\n        \\\"openai/gpt-5.4\\\": {}\\n      },\\n      \\\"workspace\\\": \\\"/vol1/@apphome/trim.openclaw/data/workspace\\\",\\n      \\\"compaction\\\": {\\n        \\\"mode\\\": \\\"safeguard\\\"\\n      },\\n      \\\"elevatedDefault\\\": \\\"full\\\",\\n      \\\"heartbeat\\\": {\\n        \\\"every\\\": \\\"3h\\\",\\n        \\\"target\\\": \\\"last\\\",\\n        \\\"directPolicy\\\": \\\"allow\\\",\\n        \\\"lightContext\\\": false,\\n        \\\"activeHours\\\": {\\n          \\\"start\\\": \\\"09:00\\\",\\n          \\\"end\\\": \\\"18:00\\\",\\n          \\\"timezone\\\": \\\"Asia/Shanghai\\\"\\n        },\\n        \\\"prompt\\\": \\\"Read HEARTBEAT.md if it exists (workspace context). Follow it strictly. Do not infer or repeat old tasks from prior chats. If nothing needs attention, reply HEARTBEAT_OK.\\\"\\n      }\\n    }\\n  },\\n  \\\"tools\\\": {\\n    \\\"elevated\\\": {\\n      \\\"enabled\\\": true,\\n      \\\"allowFrom\\\": {\\n        \\\"feishu\\\": [\\n          \\\"ou_0d8158fb9ce0f506ff8a89590d91c869\\\"\\n        ],\\n        \\\"