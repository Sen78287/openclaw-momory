{"type":"message","id":"431cf853","parentId":"2b017ade","timestamp":"2026-04-25T09:53:56.047Z","message":{"role":"toolResult","toolCallId":"call_i9rrZwuShOu99cnFxU4vMZ5D|fc_03de1a6cc6aa873f0169ec8f325bfc8196ad8156d6c215ec9a","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nimport argparse\nimport base64\nimport json\nimport mimetypes\nimport os\nimport sys\nfrom pathlib import Path\nfrom urllib import request, error\n\nDEFAULT_API_URL = os.environ.get('PY_IMAGE_GEN_API_URL', 'http://127.0.0.1:8317/v1/images/edits')\nDEFAULT_API_KEY = [REDACTED]'PY_IMAGE_GEN_API_KEY', 'sk-BWBqYMccwVdcI9OAG')\nDEFAULT_MODEL = os.environ.get('PY_IMAGE_GEN_MODEL', 'gpt-image-2')\nDEFAULT_INSTRUCTIONS = os.environ.get('PY_IMAGE_GEN_INSTRUCTIONS', 'You are a helpful assistant.')\n\n\ndef to_data_url(path: Path) -> str:\n    mime = mimetypes.guess_type(str(path))[0] or 'image/png'\n    b64 = base64.b64encode(path.read_bytes()).decode('ascii')\n    return f'data:{mime};base64,{b64}'\n\n\ndef save_bytes(path: Path, b64: str):\n    path.write_bytes(base64.b64decode(b64))\n    print(f'SAVED {path}')\n\n\ndef parse_sse_and_save(resp, out_base: str):\n    event_type = None\n    data_lines = []\n    saved = None\n\n    def maybe_save_from_obj(obj):\n        nonlocal saved\n        if not isinstance(obj, dict):\n            return\n        candidates = []\n        if isinstance(obj.get('data'), list):\n            candidates.extend(obj.get('data') or [])\n        if isinstance(obj.get('output'), list):\n            candidates.extend(obj.get('output') or [])\n        if isinstance(obj.get('response'), dict) and isinstance(obj['response'].get('output'), list):\n            candidates.extend(obj['response'].get('output') or [])\n        for item in candidates:\n            if not isinstance(item, dict):\n                continue\n            b64 = item.get('b64_json') or item.get('result')\n            if not b64:\n                continue\n            ext = item.get('output_format') or 'png'\n            out_path = Path.cwd() / f'{out_base}.{ext}'\n            save_bytes(out_path, b64)\n            saved = str(out_path)\n            return\n\n    def flush():\n        nonlocal event_type, data_lines, saved\n        if not data_lines:\n            return\n        raw = '\\n'.join(data_lines).strip()\n        if not raw or raw == '[DONE]':\n            event_type = None\n            data_lines = []\n            return\n        try:\n            obj = json.loads(raw)\n        except Exception:\n            event_type = None\n            data_lines = []\n            return\n        maybe_save_from_obj(obj)\n        event_type = None\n        data_lines = []\n\n    content_type = ''\n    try:\n        content_type = resp.headers.get('Content-Type', '')\n    except Exception:\n        content_type = ''\n\n    if 'application/json' in content_type:\n        obj = json.loads(resp.read().decode('utf-8', errors='ignore'))\n        maybe_save_from_obj(obj)\n        return saved\n\n    for raw_line in resp:\n        line = raw_line.decode('utf-8', errors='ignore').rstrip('\\r\\n')\n        if line.startswith('event:'):\n            if event_type or data_lines:\n                flush()\n            event_type = line[6:].strip()\n        elif line.startswith('data:'):\n            data_lines.append(line[5:].lstrip())\n        elif not line.strip():\n            flush()\n    flush()\n    return saved\n\n\ndef main():\n    ap = argparse.ArgumentParser(description='Edit image with responses API image input.')\n    ap.add_argument('--image', required=True)\n    ap.add_argument('--prompt', required=True)\n    ap.add_argument('--api-url', default=DEFAULT_API_URL)\n    ap.add_argument('--api-key', default=DEFAULT_API_KEY)\n    ap.add_argument('--model', default=DEFAULT_MODEL)\n    ap.add_argument('--instructions', default=DEFAULT_INSTRUCTIONS)\n    ap.add_argument('--out-base', default='edited')\n    ap.add_argument('--action', default='edit')\n    args = ap.parse_args()\n\n    image_path = Path(args.image)\n    if not image_path.exists():\n        print('ERROR image_not_found', file=sys.stderr)\n        raise SystemExit(2)\n\n    image_data_url = to_data_url(image_path)\n    body = {\n        'model': args.model,\n        'prompt': args.prompt,\n        'images': [\n            {\n                'image_url': image_data_url,\n            }\n        ],\n        'size': '1024x1024',\n        'stream': False,\n    }\n\n    data = json.dumps(body, ensure_ascii=False).encode('utf-8')\n    req = request.Request(args.api_url, data=data, method='POST')\n    req.add_header('Content-Type', 'application/json')\n    req.add_header('Authorization', f'Bearer {args.api_key}')\n\n    try:\n        with request.urlopen(req, timeout=600) as resp:\n            saved = parse_sse_and_save(resp, args.out_base)\n    except error.HTTPError as e:\n        detail = e.read().decode('utf-8', errors='ignore')\n        print(f'HTTP_ERROR {e.code} {detail}', file=sys.stderr)\n        raise SystemExit(1)\n    except Exception as e:\n        print(f'ERROR {e}', file=sys.stderr)\n        raise SystemExit(1)\n\n    if not saved:\n        print('ERROR no_image_saved', file=sys.stderr)\n        raise SystemExit(3)\n    print(f'OK {saved}')\n\n\nif __name__ == '__main__':\n    main()\n"}],"isError":false,"timestamp":1777110835931}}
