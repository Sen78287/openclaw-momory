{"type":"message","id":"572926e1","parentId":"64d9b72b","timestamp":"2026-04-25T09:42:57.644Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_ymQv8IewQoXPMsTAtZw45Zn8|fc_03de1a6cc6aa873f0169ec8c86b3708196839aa053e7a2f688","name":"edit","arguments":{"path":"/vol1/@apphome/trim.openclaw/data/home/.openclaw/skills/gpt-image-generator/scripts/generate_image.py","edits":[{"oldText":"import argparse\nimport base64\nimport json\nimport os\nimport sys\nfrom pathlib import Path\nfrom urllib import request, error\n","newText":"import argparse\nimport base64\nimport imghdr\nimport json\nimport os\nimport sys\nfrom pathlib import Path\nfrom urllib import request, error\n"},{"oldText":"def save_bytes(path: Path, b64: str):\n    path.write_bytes(base64.b64decode(b64))\n    print(f'SAVED {path}')\n\n\ndef parse_sse_and_save(resp, out_base: str):\n","newText":"def save_bytes(path: Path, b64: str):\n    path.write_bytes(base64.b64decode(b64))\n    print(f'SAVED {path}')\n\n\ndef save_image_bytes_auto(out_base: str, image_bytes: bytes):\n    ext = imghdr.what(None, h=image_bytes) or 'png'\n    out_path = Path(f'{out_base}.{ext}') if not str(out_base).endswith(f'.{ext}') else Path(out_base)\n    out_path.write_bytes(image_bytes)\n    print(f'SAVED {out_path}')\n    return str(out_path)\n\n\ndef parse_sse_and_save(resp, out_base: str):\n"},{"oldText":"def main():\n","newText":"def call_images_generations(api_url: str, api_key: str, model: str, prompt: str, out_base: str):\n    url = api_url\n    if url.endswith('/responses'):\n        url = url[:-10] + '/images/generations'\n    elif not url.endswith('/images/generations'):\n        url = url.rstrip('/') + '/images/generations'\n\n    body = {\n        'model': model,\n        'prompt': prompt,\n        'size': '1024x1536',\n    }\n    data = json.dumps(body, ensure_ascii=False).encode('utf-8')\n    req = request.Request(url, data=data, method='POST')\n    req.add_header('Content-Type', 'application/json')\n    req.add_header('Authorization', f'Bearer {api_key}')\n\n    try:\n        with request.urlopen(req, timeout=600) as resp:\n            obj = json.loads(resp.read().decode('utf-8', errors='ignore'))\n    except error.HTTPError as e:\n        detail = e.read().decode('utf-8', errors='ignore')\n        print(f'HTTP_ERROR {e.code} {detail}', file=sys.stderr)\n        raise SystemExit(1)\n    except Exception as e:\n        print(f'ERROR {e}', file=sys.stderr)\n        raise SystemExit(1)\n\n    data_items = obj.get('data') or []\n    if not data_items:\n        print('ERROR no_image_saved', file=sys.stderr)\n        raise SystemExit(2)\n\n    item = data_items[0]\n    if item.get('b64_json'):\n        saved = save_image_bytes_auto(out_base, base64.b64decode(item['b64_json']))\n        print(f'OK {saved}')\n        return\n    if item.get('url'):\n        try:\n            with request.urlopen(item['url'], timeout=600) as resp:\n                saved = save_image_bytes_auto(out_base, resp.read())\n        except Exception as e:\n            print(f'ERROR {e}', file=sys.stderr)\n            raise SystemExit(1)\n        print(f'OK {saved}')\n        return\n\n    print('ERROR no_image_saved', file=sys.stderr)\n    raise SystemExit(2)\n\n\ndef main():\n"},{"oldText":"    body = {\n        'model': args.model,\n        'instructions': args.instructions,\n        'input': [{\n            'type': 'message',\n            'role': 'user',\n            'content': [{\n                'type': 'input_text',\n                'text': args.prompt,\n            }],\n        }],\n        'tools': [{'type': 'image_generation'}],\n        'tool_choice': {'type': 'image_generation'},\n        'stream': True,\n        'store': False,\n    }\n\n    data = json.dumps(body, ensure_ascii=False).encode('utf-8')\n    req = request.Request(args.api_url, data=data, method='POST')\n    req.add_header('Content-Type', 'application/json')\n    req.add_header('Authorization', f'Bearer {args.api_key}')\n\n