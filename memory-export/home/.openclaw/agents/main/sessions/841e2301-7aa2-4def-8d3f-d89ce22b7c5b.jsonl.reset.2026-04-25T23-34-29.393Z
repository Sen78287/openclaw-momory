{"type":"message","id":"5731d30c","parentId":"912b6f13","timestamp":"2026-04-25T10:42:39.815Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_M5Pjb75DDltgOGuCsVxBifjj|fc_0915ba638edbc8bc0169ec9a9f8e708197b3d16eeb5da71f04","name":"read","arguments":{"path":"/vol1/@apphome/trim.openclaw/data/home/.openclaw/skills/gpt-image-generator/scripts/generate_image_edit.py","offset":1,"limit":260},"partialJson":"{\"path\":\"/vol1/@apphome/trim.openclaw/data/home/.openclaw/skills/gpt-image-generator/scripts/generate_image_edit.py\",\"offset\":1,\"limit\":260}"},{"type":"toolCall","id":"call_BZcUDicuvAFYaRefvg5acnpA|fc_0915ba638edbc8bc0169ec9a9f8e808197bb9291c350cd9e97","name":"read","arguments":{"path":"/vol1/@apphome/trim.openclaw/data/home/.openclaw/skills/gpt-image-generator/scripts/generate_image.py","offset":1,"limit":260},"partialJson":"{\"path\":\"/vol1/@apphome/trim.openclaw/data/home/.openclaw/skills/gpt-image-generator/scripts/generate_image.py\",\"offset\":1,\"limit\":260}"}],"api":"openai-responses","provider":"openai","model":"gpt-5.4","usage":{"input":16391,"output":117,"cacheRead":23680,"cacheWrite":0,"totalTokens":40188,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1777113755722,"responseId":"resp_0915ba638edbc8bc0169ec9a9cada08197a66be0a5758f7a14"}}
{"type":"message","id":"7626d38d","parentId":"5731d30c","timestamp":"2026-04-25T10:42:40.029Z","message":{"role":"toolResult","toolCallId":"call_M5Pjb75DDltgOGuCsVxBifjj|fc_0915ba638edbc8bc0169ec9a9f8e708197b3d16eeb5da71f04","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nimport argparse\nimport base64\nimport imghdr\nimport json\nimport mimetypes\nimport os\nimport sys\nfrom pathlib import Path\nfrom urllib import request, error\n\nDEFAULT_API_URL = os.environ.get('PY_IMAGE_GEN_API_URL', os.environ.get('OPENAI_BASE_URL', 'http://127.0.0.1:8317/v1').rstrip('/') + '/images/edits')\nDEFAULT_API_KEY = [REDACTED]'PY_IMAGE_GEN_API_KEY', os.environ.get('OPENAI_API_KEY', 'sk-xxxxx'))\nDEFAULT_MODEL = os.environ.get('PY_IMAGE_GEN_MODEL', os.environ.get('OPENAI_IMAGE_MODEL', 'gpt-image-2'))\nDEFAULT_INSTRUCTIONS = os.environ.get('PY_IMAGE_GEN_INSTRUCTIONS', 'You are a helpful assistant.')\n\n\ndef to_data_url(path: Path) -> str:\n    mime = mimetypes.guess_type(str(path))[0] or 'image/png'\n    b64 = base64.b64encode(path.read_bytes()).decode('ascii')\n    return f'data:{mime};base64,{b64}'\n\n\ndef save_bytes(path: Path, b64: str):\n    path.write_bytes(base64.b64decode(b64))\n    print(f'SAVED {path}')\n\n\ndef save_image_bytes_auto(out_base: str, image_bytes: bytes):\n    ext = imghdr.what(None, h=image_bytes) or 'png'\n    out_path = Path(f'{out_base}.{ext}') if not str(out_base).endswith(f'.{ext}') else Path(out_base)\n    out_path.write_bytes(image_bytes)\n    print(f'SAVED {out_path}')\n    return str(out_path)\n\n\ndef parse_sse_and_save(resp, out_base: str):\n    event_type = None\n    data_lines = []\n    saved = None\n\n    def maybe_save_from_obj(obj):\n        nonlocal saved\n        if not isinstance(obj, dict):\n            return\n        candidates = []\n        if isinstance(obj.get('data'), list):\n            candidates.extend(obj.get('data') or [])\n        if isinstance(obj.get('output'), list):\n            candidates.extend(obj.get('output') or [])\n        if isinstance(obj.get('response'), dict) and isinstance(obj['response'].get('output'), list):\n            candidates.extend(obj['response'].get('output') or [])\n        for item in candidates:\n            if not isinstance(item, dict):\n                continue\n            b64 = item.get('b64_json') or item.get('result')\n            if b64:\n                ext = item.get('output_format') or 'png'\n                out_path = Path.cwd() / f'{out_base}.{ext}'\n                save_bytes(out_path, b64)\n                saved = str(out_path)\n                return\n            if item.get('url'):\n                try:\n                    with request.urlopen(item['url'], timeout=600) as r:\n                        saved = save_image_bytes_auto(out_base, r.read())\n                        return\n                except Exception:\n                    continue\n\n    def flush():\n        nonlocal event_type, data_lines, saved\n        if not data_lines:\n            return\n        raw = '\\n'.join(data_lines).strip()\n        if not raw or raw == '[DONE]':\n            event_type = None\n            data_lines = []\n            return\n        try:\n            obj = json.loads(raw)\n        except Exception:\n            event_type = None\n            data_lines = []\n            return\n        maybe_save_from_obj(obj)\n        event_type = None\n        data_lines = []\n\n    content_type = ''\n    try:\n        content_type = resp.headers.get('Content-Type', '')\n    except Exception:\n        content_type = ''\n\n    if 'application/json' in content_type:\n        obj = json.loads(resp.read().decode('utf-8', errors='ignore'))\n        maybe_save_from_obj(obj)\n        return saved\n\n    for raw_line in resp:\n        line = raw_line.decode('utf-8', errors='ignore').rstrip('\\r\\n')\n        if line.startswith('event:'):\n            if event_type or data_lines:\n                flush()\n            event_type = line[6:].strip()\n        elif line.startswith('data:'):\n            data_lines.append(line[5:].lstrip())\n        elif not line.strip():\n            flush()\n    flush()\n    return saved\n\n\ndef main():\n    ap = argparse.ArgumentParser(description='Edit image with responses API image input.')\n    ap.add_argument('--image', required=True)\n    ap.add_argument('--prompt', required=True)\n    ap.add_argument('--api-url', default=DEFAULT_API_URL)\n    ap.add_argument('--api-key', default=DEFAULT_API_KEY)\n    ap.add_argument('--model', default=DEFAULT_MODEL)\n    ap.add_argument('--instructions', default=DEFAULT_INSTRUCTIONS)\n    ap.add_argument('--out-base', default='edited')\n    ap.add_argument('--action', default='edit')\n    args = ap.parse_args()\n\n    image_path = Path(args.image)\n    if not image_path.exists():\n        print('ERROR image_not_found', file=sys.stderr)\n        raise SystemExit(2)\n\n    image_data_url = to_data_url(image_path)\n    body = {\n        'model': args.model,\n        'prompt': args.prompt,\n        'images': [\n            {\n                'image_url': image_data_url,\n            }\n        ],\n        'size': '1024x1536',\n        'stream': False,\n    }\n\n    data = json.dumps(body, ensure_ascii=False).encode('utf-8')\n    req = request.Request(args.api_url, data=data, method='POST')\n    req.add_header('Content-Type', 'application/json')\n    req.add_header('Authorization', f'Bearer {args.api_key}')\n\n    try:\n        with request.urlopen(req, timeout=600) as resp:\n            saved = parse_sse_and_save(resp, args.out_base)\n    except error.HTTPError as e:\n        detail = e.read().decode('utf-8', errors='ignore')\n        print(f'HTTP_ERROR {e.code} {detail}', file=sys.stderr)\n        raise SystemExit(1)\n    except Exception as e:\n        print(f'ERROR {e}', file=sys.stderr)\n        raise SystemExit(1)\n\n    if not saved:\n        print('ERROR no_image_saved', file=sys.stderr)\n        raise SystemExit(3)\n    print(f'OK {saved}')\n\n\nif __name__ == '__main__':\n    main()\n"}],"isError":false,"timestamp":1777113759958}}
{"type":"message","id":"2fd8fd47","parentId":"7626d38d","timestamp":"2026-04-25T10:42:40.095Z","message":{"role":"toolResult","toolCallId":"call_BZcUDicuvAFYaRefvg5acnpA|fc_0915ba638edbc8bc0169ec9a9f8e808197bb9291c350cd9e97","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\nimport argparse\nimport base64\nimport imghdr\nimport json\nimport os\nimport sys\nfrom pathlib import Path\nfrom urllib import request, error\n\nDEFAULT_API_URL = os.environ.get('PY_IMAGE_GEN_API_URL', os.environ.get('OPENAI_BASE_URL', 'http://127.0.0.1:8317/v1').rstrip('/') + '/responses')\nDEFAULT_API_KEY = [REDACTED]'PY_IMAGE_GEN_API_KEY', os.environ.get('OPENAI_API_KEY', 'sk-xxxxx'))\nDEFAULT_MODEL = os.environ.get('PY_IMAGE_GEN_MODEL', os.environ.get('OPENAI_IMAGE_MODEL', 'gpt-image-2'))\nDEFAULT_INSTRUCTIONS = os.environ.get('PY_IMAGE_GEN_INSTRUCTIONS', 'You are a helpful assistant.')\n\n\ndef save_bytes(path: Path, b64: str):\n    path.write_bytes(base64.b64decode(b64))\n    print(f'SAVED {path}')\n\n\ndef save_image_bytes_auto(out_base: str, image_bytes: bytes):\n    ext = imghdr.what(None, h=image_bytes) or 'png'\n    out_path = Path(f'{out_base}.{ext}') if not str(out_base).endswith(f'.{ext}') else Path(out_base)\n    out_path.write_bytes(image_bytes)\n    print(f'SAVED {out_path}')\n    return str(out_path)\n\n\ndef parse_sse_and_save(resp, out_base: str):\n    event_type = None\n    data_lines = []\n    saved = None\n\n    def flush():\n        nonlocal event_type, data_lines, saved\n        if not event_type or not data_lines:\n            return\n        raw = '\\n'.join(data_lines).strip()\n        if not raw or raw == '[DONE]':\n            event_type = None\n            data_lines = []\n            return\n        try:\n            obj = json.loads(raw)\n        except Exception:\n            event_type = None\n            data_lines = []\n            return\n\n        def save_image_call(image_call):\n            nonlocal saved\n            if not image_call:\n                return\n            if image_call.get('type') != 'image_generation_call':\n                return\n            result = image_call.get('result')\n            if not result:\n                return\n            ext = image_call.get('output_format') or 'png'\n            out_path = Path.cwd() / f'{out_base}.{ext}'\n            save_bytes(out_path, result)\n            saved = str(out_path)\n\n        if event_type == 'response.output_item.done':\n            save_image_call(obj.get('item'))\n        elif event_type == 'response.completed':\n            response = obj.get('response', {})\n            for item in response.get('output', []) or []:\n                if item.get('type') == 'image_generation_call' and item.get('result'):\n                    save_image_call(item)\n                    break\n        event_type = None\n        data_lines = []\n\n    for raw_line in resp:\n        line = raw_line.decode('utf-8', errors='ignore').rstrip('\\r\\n')\n        if line.startswith('event:'):\n            if event_type or data_lines:\n                flush()\n            event_type = line[6:].strip()\n        elif line.startswith('data:'):\n            data_lines.append(line[5:].lstrip())\n        elif not line.strip():\n            flush()\n    flush()\n    return saved\n\n\ndef call_images_generations(api_url: str, api_key: str, model: str, prompt: str, out_base: str):\n    url = api_url\n    if url.endswith('/responses'):\n        url = url[:-10] + '/images/generations'\n    elif not url.endswith('/images/generations'):\n        url = url.rstrip('/') + '/images/generations'\n\n    body = {\n        'model': model,\n        'prompt': prompt,\n        'size': '1024x1536',\n    }\n    data = json.dumps(body, ensure_ascii=False).encode('utf-8')\n    req = request.Request(url, data=data, method='POST')\n    req.add_header('Content-Type', 'application/json')\n    req.add_header('Authorization', f'Bearer {api_key}')\n\n    try:\n        with request.urlopen(req, timeout=600) as resp:\n            obj = json.loads(resp.read().decode('utf-8', errors='ignore'))\n    except error.HTTPError as e:\n        detail = e.read().decode('utf-8', errors='ignore')\n        print(f'HTTP_ERROR {e.code} {detail}', file=sys.stderr)\n        raise SystemExit(1)\n    except Exception as e:\n        print(f'ERROR {e}', file=sys.stderr)\n        raise SystemExit(1)\n\n    data_items = obj.get('data') or []\n    if not data_items:\n        print('ERROR no_image_saved', file=sys.stderr)\n        raise SystemExit(2)\n\n    item = data_items[0]\n    if item.get('b64_json'):\n        saved = save_image_bytes_auto(out_base, base64.b64decode(item['b64_json']))\n        print(f'OK {saved}')\n        return\n    if item.get('url'):\n        try:\n            with request.urlopen(item['url'], timeout=600) as resp:\n                saved = save_image_bytes_auto(out_base, resp.read())\n        except Exception as e:\n            print(f'ERROR {e}', file=sys.stderr)\n            raise SystemExit(1)\n        print(f'OK {saved}')\n        return\n\n    print('ERROR no_image_saved', file=sys.stderr)\n    raise SystemExit(2)\n\n\ndef main():\n    parser = argparse.ArgumentParser(description='Generate image via responses API and save beside script caller cwd.')\n    parser.add_argument('prompt', help='image prompt')\n    parser.add_argument('--api-url', default=DEFAULT_API_URL)\n    parser.add_argument('--api-key', default=DEFAULT_API_KEY)\n    parser.add_argument('--model', default=DEFAULT_MODEL)\n    parser.add_argument('--instructions', default=DEFAULT_INSTRUCTIONS)\n    parser.add_argument('--out-base', default='generated')\n    args = parser.parse_args()\n\n    if args.model.startswith('gpt-image-'):\n        call_images_generations(args.api_url, args.api_key, args.model, args.prompt, args.out_base)\n        return\n\n    body = {\n        'model': args.model,\n        'instructions': args.instructions,\n        'input': [{\n            'type': 'message',\n            'role': 'user',\n            'content': [{\n                'type': 'input_text',\n                'text': args.prompt,\n            }],\n        }],\n        'tools': [{'type': 'image_generation'}],\n        'tool_choice': {'type': 'image_generation'},\n        'stream': True,\n        'store': False,\n    }\n\n    data = json.dumps(body, ensure_ascii=False).encode('utf-8')\n    req = request.Request(args.api_url, data=data, method='POST')\n    req.add_header('Content-Type', 'application/json')\n    req.add_header('Authorization', f'Bearer {args.api_key}')\n\n    try:\n        with request.urlopen(req, timeout=600) as resp:\n            saved = parse_sse_and_save(resp, args.out_base)\n    except error.HTTPError as e:\n        detail = e.read().decode('utf-8', errors='ignore')\n        print(f'HTTP_ERROR {e.code} {detail}', file=sys.stderr)\n        raise SystemExit(1)\n    except Exception as e:\n        print(f'ERROR {e}', file=sys.stderr)\n        raise SystemExit(1)\n\n    if not saved:\n        print('ERROR no_image_saved', file=sys.stderr)\n        raise SystemExit(2)\n    print(f'OK {saved}')\n\n\nif __name__ == '__main__':\n    main()\n"}],"isError":false,"timestamp":1777113760029}}
