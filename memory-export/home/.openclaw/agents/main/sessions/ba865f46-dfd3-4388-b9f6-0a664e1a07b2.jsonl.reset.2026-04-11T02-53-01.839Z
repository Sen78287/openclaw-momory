{"type":"message","id":"46c100da","parentId":"6e1f4da2","timestamp":"2026-04-09T03:34:40.039Z","message":{"role":"toolResult","toolCallId":"call_MGpLU2G8KRcr8aCBJNE6bi1L|fc_0c9b6ce96dbbda280169d71e4f60088196b14b57eea8d5cccd","toolName":"read","content":[{"type":"text","text":"import argparse\nimport hashlib\nimport json\nimport time\nimport urllib.parse\nimport urllib.request\nfrom typing import Any, Dict\n\nUSER_ID = \"D00F0DB59DF3AD97\"\nSALT = \"UETHM9sYJszN7nthlYfFNyUXi2Rv7A3n\"\nAPI = \"https://p.bokecc.com/api/mobile\"\nFIXED_PARAMS = {\n    \"authtimeout\": \"518400\",\n    \"format\": \"json\",\n    \"hlsflag\": \"0\",\n    \"httpsflag\": \"1\",\n}\n\n\ndef build_base_query(videoid: str, userid: str = USER_ID) -> str:\n    params = [\n        (\"authtimeout\", FIXED_PARAMS[\"authtimeout\"]),\n        (\"format\", FIXED_PARAMS[\"format\"]),\n        (\"hlsflag\", FIXED_PARAMS[\"hlsflag\"]),\n        (\"httpsflag\", FIXED_PARAMS[\"httpsflag\"]),\n        (\"userid\", userid),\n        (\"videoid\", videoid),\n    ]\n    return urllib.parse.urlencode(params)\n\n\ndef calc_hash(videoid: str, ts_ms: str, userid: str = USER_ID, salt: str = SALT) -> str:\n    base = build_base_query(videoid, userid)\n    sign_input = f\"{base}&time={ts_ms}&salt={salt}\"\n    return hashlib.md5(sign_input.encode(\"utf-8\")).hexdigest().upper()\n\n\ndef build_api_url(videoid: str, ts_ms: str | None = None, userid: str = USER_ID) -> str:\n    if ts_ms is None:\n        ts_ms = str(int(time.time() * 1000))\n    base = build_base_query(videoid, userid)\n    h = calc_hash(videoid, ts_ms, userid)\n    return f\"{API}?{base}&time={ts_ms}&hash={h}\"\n\n\ndef fetch_json(url: str) -> Dict[str, Any]:\n    req = urllib.request.Request(\n        url,\n        headers={\n            \"User-Agent\": \"Mozilla/5.0\",\n            \"Accept\": \"application/json,text/plain,*/*\",\n        },\n    )\n    with urllib.request.urlopen(req, timeout=20) as resp:\n        return json.loads(resp.read().decode(\"utf-8\", errors=\"replace\"))\n\n\ndef extract_playurls(data: Dict[str, Any]) -> list[str]:\n    urls: list[str] = []\n    video = data.get(\"video\") or {}\n    for item in video.get(\"copy\") or []:\n        playurl = item.get(\"playurl\")\n        if playurl:\n            urls.append(playurl)\n    return urls\n\n\ndef main() -> None:\n    parser = argparse.ArgumentParser(description=\"Build and optionally fetch BokeCC mobile play URLs\")\n    parser.add_argument(\"videoid\", help=\"BokeCC videoid / ccIdNew\")\n    parser.add_argument(\"--time\", dest=\"ts_ms\", help=\"milliseconds timestamp to use\")\n    parser.add_argument(\"--userid\", default=USER_ID)\n    parser.add_argument(\"--print-hash\", action=\"store_true\", help=\"print only the computed hash\")\n    parser.add_argument(\"--fetch\", action=\"store_true\", help=\"request /api/mobile and print playurls\")\n    parser.add_argument(\"--json\", action=\"store_true\", help=\"print full JSON when used with --fetch\")\n    args = parser.parse_args()\n\n    ts_ms = args.ts_ms or str(int(time.time() * 1000))\n    h = calc_hash(args.videoid, ts_ms, args.userid)\n\n    if args.print_hash:\n        print(h)\n        return\n\n    url = build_api_url(args.videoid, ts_ms, args.userid)\n    print(url)\n\n    if not args.fetch:\n        return\n\n    data = fetch_json(url)\n    if args.json:\n        print(json.dumps(data, ensure_ascii=False, indent=2))\n        return\n\n    playurls = extract_playurls(data)\n    if not playurls:\n        print(\"[!] no playurl found in response\")\n        return\n\n    for idx, playurl in enumerate(playurls, 1):\n        print(f\"[{idx}] {playurl}\")\n\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1775705680021}}
{"type":"message","id":"4d59b67d","parentId":"46c100da","timestamp":"2026-04-09T03:34:47.260Z","message":{"role":"assistant","content":[{"type":"text","text":"[[reply_to_current]] 这是个 Python 脚本，不是图片。内容看起来是在生成/请求保利威（BokeCC）视频播放地址的：\n\n- 固定了 `USER_ID`\n- 固定了 `SALT`\n- 按参数串 + `time` + `salt` 做 `MD5`\n- 请求 `https://p.bokecc.com/api/mobile`\n- 还能把返回里的 `playurl` 提取出来\n\n如果你是想让我帮你处理它，我可以直接继续做其中一种：\n\n1. **解释这段脚本在干嘛**\n2. **帮你运行它，生成某个 `videoid` 的播放链接**\n3. **帮你审计：看签名算法/参数有没有问题**\n4. **改造成更好用的版本**，比如：\n   - 支持命令行参数\n   - 批量跑多个 `videoid`\n   - 输出完整 JSON / m3u8\n   - 自动重试、保存结果\n\n如果你愿意，我下一步可以直接帮你：**把这个脚本跑起来并验证是否还能拿到 playurl**。  \n你只要发我目标 `videoid`，或者说一句：**“直接帮我测这个脚本”**。","textSignature":"{\"v\":1,\"id\":\"msg_04776ea2edad842c0169d71e51f600819681eed20fa8caed4c\",\"phase\":\"final_answer\"}"}],"api":"openai-responses","provider":"openai","model":"gpt-5.4","usage":{"input":24833,"output":278,"cacheRead":0,"cacheWrite":0,"totalTokens":25111,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"stop","timestamp":1775705680027,"responseId":"resp_04776ea2edad842c0169d71e50ff9881968d28c4cac6f76499"}}
