w/docs/assets/openclaw-logo-text-dark.png\n/vol1/@apphome/trim.openclaw/data/openclaw/node_modules/openclaw/docs/assets/openclaw-logo-text.png\n/vol1/@apphome/trim.openclaw/data/openclaw/node_modules/openclaw/docs/assets/install-script.svg\n/vol1/@apphome/trim.openclaw/data/openclaw/node_modules/openclaw/docs/assets/openclaw-logo-text-dark.svg\n/vol1/@apphome/trim.openclaw/data/openclaw/node_modules/openclaw/docs/assets/openclaw-logo-text.svg\n/vol1/@apphome/trim.openclaw/data/openclaw/node_modules/openclaw/docs/assets/pixel-lobster.svg\n/vol1/@apphome/trim.openclaw/data/openclaw/node_modules/openclaw/docs/whatsapp-openclaw-ai-zh.jpg\n/vol1/@apphome/trim.openclaw/data/openclaw/node_modules/openclaw/docs/whatsapp-openclaw.jpg\n/vol1/@apphome/trim.openclaw/data/openclaw/node_modules/openclaw/docs/nav-tabs-underline.js\n/vol1/@apphome/trim.openclaw/data/openclaw/node_modules/openclaw/docs/docs.json\n/vol1/@apphome/trim.openclaw/data/openclaw/node_modules/openclaw/docs/.i18n/glossary.ja-JP.json\n/vol1/@apphome/trim.openclaw/data/openclaw/node_modules/openclaw/docs/.i18n/glossary.zh-CN.json\n/vol1/@apphome/trim.openclaw/data/openclaw/node_modules/openclaw/docs/.i18n/ja-JP.tm.jsonl\n/vol1/@apphome/trim.openclaw/data/openclaw/node_modules/openclaw/docs/.i18n/README.md\n/vol1/@apphome/trim.openclaw/data/openclaw/node_modules/openclaw/docs/reference/secretref-user-supplied-credentials-matrix.json\n/vol1/@apphome/trim.openclaw/data/openclaw/node_modules/openclaw/docs/reference/AGENTS.default.md\n/vol1/@apphome/trim.openclaw/data/openclaw/node_modules/openclaw/docs/reference/api-usage-costs.md\n/vol1/@apphome/trim.openclaw/data/openclaw/node_modules/openclaw/docs/reference/credits.md\n/vol1/@apphome/trim.openclaw/data/openclaw/node_modules/openclaw/docs/reference/device-models.md\n/vol1/@apphome/trim.openclaw/data/openclaw/node_modules/openclaw/docs/reference/memory-config.md\n/vol1/@apphome/trim.openclaw/data/openclaw/node_modules/openclaw/docs/reference/prompt-caching.md\n/v